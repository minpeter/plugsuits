{
  "name": "@ai-sdk-tool/harness",
  "version": "1.3.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@ai-sdk-tool/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compaction": {
      "@ai-sdk-tool/source": "./src/subpath/compaction.ts",
      "import": "./dist/subpath/compaction.js",
      "types": "./dist/subpath/compaction.d.ts"
    },
    "./sessions": {
      "@ai-sdk-tool/source": "./src/subpath/sessions.ts",
      "import": "./dist/subpath/sessions.js",
      "types": "./dist/subpath/sessions.d.ts"
    },
    "./runtime": {
      "@ai-sdk-tool/source": "./src/subpath/runtime.ts",
      "types": "./dist/subpath/runtime.d.ts",
      "import": "./dist/subpath/runtime.js"
    },
    "./memory": {
      "@ai-sdk-tool/source": "./src/subpath/memory.ts",
      "import": "./dist/subpath/memory.js",
      "types": "./dist/subpath/memory.d.ts"
    },
    "./preferences": {
      "@ai-sdk-tool/source": "./src/subpath/preferences.ts",
      "import": "./dist/subpath/preferences.js",
      "types": "./dist/subpath/preferences.d.ts"
    },
    "./mcp": {
      "@ai-sdk-tool/source": "./src/subpath/mcp.ts",
      "import": "./dist/subpath/mcp.js",
      "types": "./dist/subpath/mcp.d.ts"
    },
    "./commands": {
      "@ai-sdk-tool/source": "./src/subpath/commands.ts",
      "import": "./dist/subpath/commands.js",
      "types": "./dist/subpath/commands.d.ts"
    },
    "./skills": {
      "@ai-sdk-tool/source": "./src/subpath/skills.ts",
      "import": "./dist/subpath/skills.js",
      "types": "./dist/subpath/skills.d.ts"
    },
    "./utils": {
      "@ai-sdk-tool/source": "./src/subpath/utils.ts",
      "import": "./dist/subpath/utils.js",
      "types": "./dist/subpath/utils.d.ts"
    },
    "./env-node": {
      "@ai-sdk-tool/source": "./src/env-node.ts",
      "import": "./dist/env-node.js",
      "types": "./dist/env-node.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minpeter/plugsuits.git",
    "directory": "packages/harness"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc && node ../../scripts/fix-esm-imports.mjs dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.36",
    "@ai-sdk/provider": "^3.0.8",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "^6.0.168",
    "glob": "^13.0.6",
    "yaml": "2.8.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0 || ^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
