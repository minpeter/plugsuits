{
  "name": "@plugsuits/minimal-agent",
  "version": "0.2.8",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "benchmark": "node --conditions=@ai-sdk-tool/source --import tsx benchmark.ts",
    "build": "tsc && node ../../scripts/fix-esm-imports.mjs dist",
    "dev": "node --watch --conditions=@ai-sdk-tool/source --import tsx index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk-tool/harness": "workspace:*",
    "@ai-sdk-tool/headless": "workspace:*",
    "@ai-sdk-tool/tui": "workspace:*",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@mariozechner/pi-tui": "^0.57.1",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "^6.0.168",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
