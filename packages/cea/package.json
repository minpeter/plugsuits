{
  "name": "plugsuits",
  "version": "2.0.0",
  "description": "A code-editing agent using Vercel AI SDK and FriendliAI",
  "type": "module",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "cli.js",
    "src",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minpeter/plugsuits.git",
    "directory": "packages/cea"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "plugsuits": "cli.js",
    "pss": "cli.js"
  },
  "scripts": {
    "start": "bun run src/entrypoints/main.ts",
    "dev": "bun run --watch src/entrypoints/main.ts",
    "build": "tsc && cp -r src/tools/**/*.txt dist/tools/",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bunx ultracite check",
    "lint": "bunx ultracite fix"
  },
  "dependencies": {
    "@ai-sdk-tool/harness": "^1.0.0",
    "@ai-sdk-tool/headless": "^0.1.0",
    "@ai-sdk-tool/parser": "^4.1.4",
    "@ai-sdk-tool/tui": "^0.1.0",
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@friendliai/ai-provider": "^1.1.7",
    "@mariozechner/pi-tui": "^0.57.1",
    "@t3-oss/env-core": "^0.13.10",
    "ai": "^6.0.116",
    "citty": "^0.2.1",
    "diff": "^8.0.3",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@biomejs/biome": "2.4.6",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.2.5"
  }
}
