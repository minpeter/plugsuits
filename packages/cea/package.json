{
  "name": "plugsuits",
  "version": "2.3.3",
  "description": "A code-editing agent using Vercel AI SDK and Anthropic",
  "type": "module",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "cli.js",
    "src",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minpeter/plugsuits.git",
    "directory": "packages/cea"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "plugsuits": "cli.js",
    "pss": "cli.js"
  },
  "scripts": {
    "dev": "node --watch --conditions=@ai-sdk-tool/source --import tsx src/entrypoints/main.ts",
    "build": "tsc && node scripts/postbuild.mjs && node ../../scripts/fix-esm-imports.mjs dist",
    "test": "vitest run src",
    "typecheck": "tsc --noEmit",
    "check": "pnpm exec ultracite check .",
    "lint": "pnpm exec ultracite fix ."
  },
  "dependencies": {
    "@ai-sdk-tool/harness": "workspace:*",
    "@ai-sdk-tool/headless": "workspace:*",
    "@ai-sdk-tool/parser": "^4.1.5",
    "@ai-sdk-tool/tui": "workspace:*",
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@mariozechner/pi-tui": "^0.57.1",
    "@t3-oss/env-core": "^0.13.10",
    "ai": "^6.0.116",
    "citty": "^0.2.1",
    "diff": "^8.0.3",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "zod": "^4.3.6"
    }
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^3.0.22",
    "@biomejs/biome": "2.4.6",
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.2.5"
  }
}
