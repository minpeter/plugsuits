{
  "name": "plugsuits",
  "version": "2.3.4",
  "description": "A code-editing agent using Vercel AI SDK with shared AI_* runtime configuration",
  "type": "module",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "cli.js",
    "src",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minpeter/plugsuits.git",
    "directory": "packages/cea"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "plugsuits": "cli.js",
    "pss": "cli.js"
  },
  "scripts": {
    "dev": "node --watch --conditions=@ai-sdk-tool/source --import tsx src/entrypoints/main.ts",
    "build": "tsc && node scripts/postbuild.mjs && node ../../scripts/fix-esm-imports.mjs dist",
    "test": "vitest run src",
    "typecheck": "tsc --noEmit",
    "check": "pnpm exec ultracite check .",
    "lint": "pnpm exec ultracite fix ."
  },
  "dependencies": {
    "@ai-sdk-tool/harness": "workspace:*",
    "@ai-sdk-tool/headless": "workspace:*",
    "@ai-sdk-tool/parser": "^4.1.20",
    "@ai-sdk-tool/tui": "workspace:*",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@mariozechner/pi-tui": "^0.68.0",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "^6.0.168",
    "citty": "^0.2.2",
    "diff": "^9.0.0",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "yaml": "2.8.3",
    "zod": "^4.3.6"
  },
  "overrides": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.23",
    "@biomejs/biome": "2.4.12",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "ultracite": "^7.6.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
