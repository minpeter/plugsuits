{
  "name": "@ai-sdk-tool/headless",
  "version": "3.1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@ai-sdk-tool/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./session": {
      "@ai-sdk-tool/source": "./src/session-headless.ts",
      "types": "./dist/session-headless.d.ts",
      "import": "./dist/session-headless.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minpeter/plugsuits.git",
    "directory": "packages/headless"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc && node ../../scripts/fix-esm-imports.mjs dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src"
  },
  "peerDependencies": {
    "@ai-sdk-tool/harness": "^1.2.4",
    "ai": "^6.0.116"
  },
  "devDependencies": {
    "@ai-sdk-tool/harness": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
