# Group chat prerequisites:
# The bot must be a group admin OR have Privacy Mode disabled in BotFather
# (Bot Settings → Group Privacy → Turn off) to receive non-command messages.

TELEGRAM_BOT_TOKEN=123456:ABCDEF...
TELEGRAM_BOT_USERNAME=mybot
TRIGGER_WORDS=bot,robot
REDIS_URL=redis://localhost:6379
AI_API_KEY=sk-...
AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL_ID=gpt-4o
# MAX_ITERATIONS=10
# LOG_LEVEL=info
# TELEGRAM_API_BASE_URL=https://api.telegram.org
# TELEGRAM_WEBHOOK_SECRET_TOKEN=
# SESSION_DIR=/tmp/tgbot-sessions
