{
  "name": "@plugsuits/tgbot",
  "version": "0.1.0",
  "description": "Telegram bot powered by Chat SDK + @ai-sdk-tool/harness",
  "type": "module",
  "main": "dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "@ai-sdk-tool/source": "./src/main.ts",
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node --watch --env-file=.env --conditions=@ai-sdk-tool/source --import tsx src/main.ts",
    "build": "tsc && node ../../scripts/fix-esm-imports.mjs dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk-tool/harness": "workspace:*",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@chat-adapter/state-redis": "latest",
    "@chat-adapter/telegram": "latest",
    "@t3-oss/env-core": "^0.13.10",
    "ai": "^6.0.116",
    "chat": "latest",
    "undici": "^8.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
