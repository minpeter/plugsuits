{
  "name": "@plugsuits/tgbot",
  "version": "0.1.3",
  "private": true,
  "description": "Telegram bot powered by Chat SDK + @ai-sdk-tool/harness",
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env --conditions=@ai-sdk-tool/source --import tsx src/main.ts",
    "build": "tsc && node ../../scripts/fix-esm-imports.mjs dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk-tool/harness": "workspace:*",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@chat-adapter/state-redis": "^4.23.0",
    "@chat-adapter/telegram": "^4.23.0",
    "@t3-oss/env-core": "^0.13.10",
    "ai": "^6.0.116",
    "chat": "^4.23.0",
    "undici": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
