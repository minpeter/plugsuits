{
  "name": "@plugsuits/tgbot",
  "version": "0.1.5",
  "private": true,
  "description": "Telegram bot powered by Chat SDK + @ai-sdk-tool/harness with shared AI_* runtime configuration",
  "type": "module",
  "scripts": {
    "dev": "node --watch --conditions=@ai-sdk-tool/source --import tsx src/main.ts",
    "build": "tsc && node ../../scripts/fix-esm-imports.mjs dist",
    "test": "vitest run src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk-tool/harness": "workspace:*",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@chat-adapter/state-redis": "^4.26.0",
    "@chat-adapter/telegram": "^4.26.0",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "^6.0.168",
    "chat": "^4.26.0",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
