{
  "name": "cea-monorepo",
  "version": "1.0.0",
  "description": "A code-editing agent using Vercel AI SDK and FriendliAI",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "bun run --cwd packages/cea dev",
    "test": "bun test packages/harness/src packages/tui/src packages/headless/src packages/cea/src",
    "typecheck": "bun run typecheck:root && turbo run typecheck",
    "typecheck:root": "tsc --noEmit -p tsconfig.root.json",
    "check": "bunx ultracite check .",
    "lint": "bunx ultracite fix .",
    "start": "bun run --cwd packages/cea start",
    "headless": "bun run --cwd packages/cea headless",
    "test:headless-edit": "bun run scripts/test-headless-edit-ops.ts",
    "test:headless-edit-edge": "bun run scripts/test-headless-edit-edge-cases.ts",
    "changeset": "changeset",
    "version-packages": "changeset version && bun install",
    "release": "bun run build && changeset publish"
  },
  "keywords": [
    "ai",
    "agent",
    "code-editing",
    "friendliai",
    "vercel-ai-sdk"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@changesets/cli": "^2.29.8",
    "turbo": "^2.5.6",
    "ultracite": "^7.2.4"
  }
}
